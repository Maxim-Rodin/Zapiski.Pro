FROM node:22-alpine AS web-build
WORKDIR /src

COPY miniapp/ ./miniapp/
COPY landing/ ./landing/

ARG VITE_API_URL=https://api.app-zapisi-pro.site
ENV VITE_API_URL=$VITE_API_URL
RUN cd miniapp \
    && npm ci --no-audit --no-fund \
    && npm run build \
    && rm -rf node_modules

RUN cd landing \
    && npm ci --no-audit --no-fund \
    && npm run build \
    && rm -rf node_modules .next .next-dev

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=web-build /src/miniapp/dist /usr/share/nginx/miniapp
COPY --from=web-build /src/landing/out /usr/share/nginx/landing

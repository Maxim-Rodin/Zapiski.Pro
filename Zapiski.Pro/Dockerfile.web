FROM node:22-alpine AS miniapp-build
WORKDIR /src/miniapp

COPY miniapp/package*.json ./
RUN npm ci

COPY miniapp/ ./
ARG VITE_API_URL=https://api.app-zapisi-pro.site
ENV VITE_API_URL=$VITE_API_URL
RUN npm run build

FROM node:22-alpine AS landing-build
WORKDIR /src/landing

COPY landing/package*.json ./
RUN npm ci

COPY landing/ ./
RUN npm run build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=miniapp-build /src/miniapp/dist /usr/share/nginx/miniapp
COPY --from=landing-build /src/landing/out /usr/share/nginx/landing
